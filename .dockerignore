.git
.gitignore
.vscode/
.idea/
.DS_Store
bin/
*.exe
*.test
*.out

.env
tokens/default.token.json
accounts/account.config.json
internal/channel_record/channels.json
*.log

# Allow folders / templates
!tokens/.gitkeep
!accounts/
!internal/channel_record/
!internal/templates/account.example.json
!internal/templates/channels.example.json
!internal/templates/env.example